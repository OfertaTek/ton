/* ============================================== NON-CRITICAL CSS — Loaded asynchronously Below-the-fold sections: benefits, flags, testimonials, FAQ, CTA, footer, sticky bar ============================================== */ .section-benefits { background-color: var(--ton-light); padding: 3rem 0 } .section-title { text-align: center; color: var(--ton-dark); margin-bottom: 2rem; font-size: 1.5rem; font-weight: 800 } .section-title span { color: var(--ton-green-text) } .grid-cards { grid-template-columns: 1fr; gap: 1.5rem; display: grid } .card { box-shadow: var(--shadow-card); border-bottom: 4px solid var(--ton-green); text-align: center; background: #fff; border-radius: 21px; flex-direction: column; align-items: center; gap: 1rem; padding: 2rem 1.5rem; transition: transform .2s, box-shadow .2s; display: flex } .card-icon { justify-content: center; align-items: center; width: 48px; height: 48px; font-size: 2rem; display: flex } .card h3 { color: #111827; font-size: 1.25rem } .card p { color: #6b7280; font-size: .95rem } .section-flags { text-align: center; content-visibility: auto; contain-intrinsic-size: auto 500px; background: #fff; padding: 3rem 0 } .flags-wrapper { flex-wrap: wrap; justify-content: center; align-items: center; gap: 1.25rem 2rem; max-width: 900px; margin: 1.5rem auto 0; display: flex } .flag-svg { width: auto; height: 48px; margin: 0 .5rem } .link-flags { color: var(--ton-green-text); margin-top: 1.75rem; font-size: .95rem; font-weight: 600; text-decoration: underline; display: inline-block } .section-cta-dark { color: #fff; text-align: center; content-visibility: auto; contain-intrinsic-size: auto 300px; background: linear-gradient(135deg, #111827 0%, #1e293b 100%); padding: 4rem 0; margin-bottom: -1px } .section-cta-dark h2 { margin-bottom: 1.5rem; font-size: 1.75rem } .card:hover { transform: translateY(-4px); box-shadow: 0 8px 16px -4px #00000026, 0 4px 8px -2px #0000001a } .sticky-footer { z-index: 100; background: #fff; border-top: 1px solid #e5e7eb; justify-content: space-between; align-items: flex-start; gap: .5rem; width: 100%; padding: .8rem 1rem; display: flex; position: fixed; bottom: 0; left: 0; box-shadow: 0 -4px 10px #0000001a } .sticky-price { flex-direction: column; align-items: flex-start; gap: .3rem; display: flex } .sticky-price span:first-child { color: #6b7280; font-size: .75rem } .sticky-price span:last-child { color: var(--ton-dark); font-size: 1.1rem; font-weight: 800 } .sticky-btn { background-color: var(--ton-green); color: #1a1a1a; white-space: nowrap; text-align: center; border-radius: 25px; flex-shrink: 0; padding: .75rem 1.5rem; font-size: .9rem; font-weight: 700 } .footer-content { flex-direction: column; align-items: center; gap: 10px; display: flex } .disclaimer { color: #9ca3af; opacity: .9; margin-top: .5rem } footer { background-color: var(--ton-dark); color: #9ca3af; padding: 3rem 0 1.5rem; font-size: .875rem } .footer-grid { gap: 2rem; display: grid } .footer-title { color: #fff; margin-bottom: 1rem; font-size: 1rem; font-weight: 700 } .footer-links a { color: #d1d5db; margin-bottom: .25rem; padding: 12px 0; transition: color .2s; display: block } .footer-links a:hover { color: #fff } @media (width>=768px) { .sticky-footer { display: none } .grid-cards, .testimonials-grid { grid-template-columns: repeat(3, 1fr) } footer { padding-bottom: 2rem } .footer-grid { grid-template-columns: repeat(2, 1fr) } } .section-testimonials { content-visibility: auto; contain-intrinsic-size: auto 400px; background: #fff; padding: 3rem 0 } .testimonials-grid { grid-template-columns: 1fr; gap: 1.5rem; margin-top: 2rem; display: grid } .testimonial-card { background: var(--ton-light); border-left: 4px solid var(--ton-green); border-radius: 16px; padding: 1.5rem } .testimonial-stars { color: #f59e0b; margin-bottom: .5rem; font-size: 1rem } .testimonial-text { color: var(--text-main); margin-bottom: .75rem; font-size: .95rem; font-style: italic; line-height: 1.6 } .testimonial-author { color: var(--ton-green-text); font-size: .85rem; font-weight: 700 } .testimonial-role { color: var(--text-muted); font-size: .8rem; font-weight: 400 } .section-faq { background: var(--ton-light); content-visibility: auto; contain-intrinsic-size: auto 500px; padding: 3rem 0 } .faq-list { max-width: 750px; margin: 2rem auto 0 } .faq-item { background: #fff; border-radius: 12px; margin-bottom: .75rem; box-shadow: 0 1px 3px #0000000f } .faq-item summary { color: var(--ton-dark); cursor: pointer; justify-content: space-between; align-items: center; min-height: 48px; padding: 1rem 1.25rem; font-size: .95rem; font-weight: 700; list-style: none; display: flex } .faq-item summary:after { content: "+"; color: var(--ton-green); font-size: 1.3rem; font-weight: 700; transition: transform .2s } .faq-item[open] summary:after { content: "−" } .faq-item summary:hover { background-color: #f9fafb } .faq-item summary::-webkit-details-marker { display: none } .faq-answer { color: var(--text-muted); padding: 0 1.25rem 1rem; font-size: .9rem; line-height: 1.7 } .cta-benefits { flex-wrap: wrap; justify-content: center; gap: .75rem 2rem; margin: 1rem 0 1.5rem; font-size: .95rem; list-style: none; display: flex } .cta-benefits li { align-items: center; gap: .4rem; display: flex } .cta-benefits .check-icon { color: var(--ton-green); font-weight: 700 } .lazy-hidden { opacity: 0; transition: opacity .3s, transform .3s; transform: translateY(10px) } .lazy-visible { opacity: 1; transform: translateY(0) }
